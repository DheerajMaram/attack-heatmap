# Copy this file to .env and fill in your values.
# Keys below mirror common .env layouts; only variables read by attck-heatmap are marked (CLI).

# --- ATT&CK / core (CLI) ---
# Label in gaps.md / layer (default matches pinned STIX below)
ATTCK_VERSION=18.1
# Optional: override STIX JSON URL (default = MITRE ATT&CK v18.1 enterprise-attack.json)
# STIX_BUNDLE_URL=https://raw.githubusercontent.com/mitre/cti/ATT%26CK-v18.1/enterprise-attack/enterprise-attack.json

# --- abuse.ch Auth-Key (https://auth.abuse.ch/) — ThreatFox, MalwareBazaar, URLhaus, YARAify (CLI) ---
# Use either THREATFOX_AUTH_KEY or THREATFOX_API_KEY (same value).
THREATFOX_AUTH_KEY=
THREATFOX_API_KEY=
MALWAREBAZAAR_AUTH_KEY=
MALWAREBAZAAR_API_KEY=
URLHAUS_AUTH_KEY=
URLHAUS_API_KEY=
YARAIFY_AUTH_KEY=
YARAIFY_API_KEY=
YARAIFY_IDENTIFIER=

# --- VirusTotal v3 (CLI) ---
# If VIRUSTOTAL_API_KEY is non-empty, set VT_TIER=free|paid or pass --vt-tier / use -i.
VIRUSTOTAL_API_KEY=
VT_TIER=free
VT_MAX_LOOKUPS=
VT_MIN_INTERVAL_SEC=
# Free tier: set true to VT-lookup http(s) URLs (missing malware_family only); uses quota
VT_INCLUDE_URLS=

# Legacy / alternate VT toggles (not read by current main.py — safe to omit)
VT_ENABLED=
VT_HASH_LIMIT=
VT_IOC_LIMIT=

# --- TIE / Sigma / feeds (CLI where noted) ---
# TIE_MODEL_PATH: technique co-occurrence matrix (JSON). Repo ships data/tie_cooccurrence_matrix.json
# built from CTID TIE public data — https://github.com/center-for-threat-informed-defense/technique-inference-engine
# Regenerate: python scripts/build_tie_cooccurrence.py
TIE_ENABLED=true
TIE_TOP_N=20
TIE_MODEL_PATH=data/tie_cooccurrence_matrix.json

FEED_DAYS_BACK=7
REQUEST_TIMEOUT=30

# --- Malpedia / MISP enrichment (CLI) ---
MALPEDIA_API_KEY=
MISP_GALAXY_ATTACK_PATTERN_PATH=
ENRICHER_ENABLED=true

# --- OTX AlienVault (not wired in current CLI) ---
OTX_API_KEY=
OTX_ENABLED=true
OTX_PAGE_LIMIT=10

# --- Other feeds / enrichments (not wired in current CLI) ---
RANSOMWARE_LIVE_ENABLED=true
OPENPHISH_ENABLED=true
OPENPHISH_MAX_IOCS=500
PHISHSTATS_ENABLED=true
PHISHSTATS_MIN_SCORE=6.0
PHISHSTATS_MAX_PAGES=3
KEV_ENABLED=true
KEV_CACHE_TTL_HOURS=24
D3FEND_ENABLED=true
D3FEND_CACHE_TTL_HOURS=168

# --- Detection priority weights (not wired in current CLI) ---
PRIORITY_SCORE_WEIGHTS_TIE=0.35
PRIORITY_SCORE_WEIGHTS_KEV=0.30
PRIORITY_SCORE_WEIGHTS_ACTOR=0.20
PRIORITY_SCORE_WEIGHTS_INDUSTRY=0.15

